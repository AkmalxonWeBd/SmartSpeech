{
  "expo": {
    "name": "SmartSpeech",
    "slug": "smart-speech",
    "version": "2.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.jpg",
    "scheme": "smartspeech",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone."
      },
      "bundleIdentifier": "com.darklogicax.smartspeech"
    },

    "android": {
      "package": "com.darklogicax.smartspeech",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      "expo-mail-composer",
      "expo-asset",
      "expo-build-properties",
      "expo-speech-recognition",
      "expo-audio"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "owner": "darklogic.ax",

    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5a212cd-1692-491a-ac92-ba273895867f"
      }
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "url": "https://u.expo.dev/a5a212cd-1692-491a-ac92-ba273895867f",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
